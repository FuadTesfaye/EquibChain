{
  "name": "equbchain",
  "version": "0.1.0",
  "description": "Decentralized rotating savings protocol on Solana",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "programs/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "anchor:build": "anchor build",
    "anchor:test": "anchor test",
    "anchor:deploy": "anchor deploy",
    "program:test": "cd programs/equbchain && cargo test",
    "web:dev": "cd apps/web && next dev",
    "web:build": "cd apps/web && next build",
    "agent:dev": "cd apps/agent && pnpm dev",
    "agent:build": "cd apps/agent && pnpm build",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json}": ["biome check --write --no-errors-on-unmatched"],
    "*.{rs,Cargo.toml}": ["cargo fmt --", "cargo clippy -- -D warnings"]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.3",
    "@types/node": "^20.17.6",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "turbo": "^2.2.3",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
